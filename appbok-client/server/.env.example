# Kopiera till .env och fyll i (server/.env är gitignored).
# Lokalt: npm run dev — API + Vite delar ofta samma origin (localhost:5173 proxar /api).

# Publik bas-URL för länkar i mejl (t.ex. /api/verify?token=...).
PUBLIC_APP_URL=http://localhost:5173

# Admin efter e-postverifiering (samma som ovan för lokal dev; i prod: https://admin.appbok.se).
ADMIN_APP_URL=http://localhost:5173

# Resend (välkomstmejl) — valfritt om SMTP redan är satt i email.js.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Appbok <hej@appbok.se>
