# Kopiera till .env och fyll i (server/.env är gitignored).
# Lokalt: npm run dev — API + Vite delar ofta samma origin (localhost:5173 proxar /api).

# Publik bas-URL för länkar i mejl (t.ex. /api/verify?token=...).
PUBLIC_APP_URL=http://localhost:5173

# Admin efter e-postverifiering (samma som ovan för lokal dev; i prod: https://admin.appbok.se).
ADMIN_APP_URL=http://localhost:5173

# Google Kalender (OAuth) — krävs för /api/calendar/* och synk av bokningar.
# Skapa OAuth 2.0-klient i Google Cloud Console (Desktop eller Web) med redirect URI nedan.
# I Vercel: lägg samma variabler under Project → Settings → Environment Variables (Production + Preview).
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
# Lokalt: redirect måste matcha exakt det som står i Google Console (oftast API-porten):
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/callback
# I produktion (samma path på er API-domän):
# GOOGLE_REDIRECT_URI=https://www.appbok.se/api/calendar/callback

# Resend (välkomstmejl) — valfritt om SMTP redan är satt i email.js.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Appbok <hej@appbok.se>
